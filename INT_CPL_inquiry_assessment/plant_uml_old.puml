' describe sequence of events
'''''''''''''''''''''''''''''''''''''''''''''''''

Requestor -> zoral : INT_CPL_inquiry_assessment 

== Validate Input Params ==

  zoral -> zoral : Validation input param
  alt If Validation Error
  note right of zoral
      Hard stop and return status.code  2000
  end note
  end


== Query Mapping ==

  group Query Assessment data
    zoral -> mas_corp_assessment_mapping : Inquiry data from DB

    activate mas_corp_assessment_mapping
      note right of mas_corp_assessment_mapping
        **WHERE** customer_type = <color blue>**"$customerType"**</color>
      end note

    mas_corp_assessment_mapping --> zoral : get mapping response

    deactivate mas_corp_assessment_mapping
 
    alt if any database error
      note right of zoral
        hard stop and return HTTP status 200, status.code = 9100
      end note
    end alt

  group #yellow filter mapping
    loop mapping list
        zoral -> zoral : condition assessmentType in <color blue>**$assessmentType**</color>
    end
        alt if mapping length != 0
            alt if "CREATE_LOAN","CHANGE_LOAN","OVERDRAFT" in assessmentType
            group Query Assessment data
    zoral -> mas_product_matrix : Inquiry data from DB
    activate mas_product_matrix
      note right of mas_product_matrix
        **WHERE** product_concat = <color blue>**"$productConcat"**</color>

        **WHERE** product_concat = <color blue>**"$productConcat"**</color>
        AND calculation_tool = <color blue>**"true"**</color>

        **WHERE** product_concat = <color blue>**"$productConcat"**</color>
        AND calculation_tool not like <color blue>**"%CAP%"**</color>
      end note
      note right of mas_product_matrix
        result : {
        crr_flag
        csr_flag
        }
        listsNullType : {
        product_concat
        customer_type
        }
        listsOtherType : {
        product_concat
        customer_type
        }
      end note
    mas_product_matrix --> zoral : get matrix response

    deactivate mas_product_matrix
   group #yellow filter product matrix
    alt if productMatrix == 0 and productMaxtrix[0].crr_flag == 'N' and productMaxtrix[0].csr_flag == 'N'
        note right of zoral
          hard stop and return HTTP status 400
        end note
    end alt
    loop filter mapping list
        alt #turquoise productMaxtrix[0].crr_flag == 'Y' and productMaxtrix[0].csr_flag == 'Y'
        note right of zoral
            (crr_weight != null and csr_weight != null) or
            (crr_weight == null and csr_weight != null) or
            (crr_weight != null and csr_weight == null)
        end note    
        else productMaxtrix[0].crr_flag == 'Y' and productMaxtrix[0].csr_flag == 'N'
        note right of zoral
            crr_weight != null and csr_weight == null
        end note    
        else productMaxtrix[0].crr_flag == 'N' and productMaxtrix[0].csr_flag == 'Y'
        note right of zoral
            crr_weight == null and csr_weight != null
        end note
        else otherwise
        note right of zoral
            false
        end note
        end alt
    end
    zoral -> zoral : keep response to globalVariables mapping
  end group


end group
        else mapping length > 1
        zoral -> vw_lov_occupation_agricultural : Inquiry data from DB 
        activate vw_lov_occupation_agricultural
        zoral -> vw_lov_occupation_non_agricultural : Inquiry data from DB
        activate vw_lov_occupation_non_agricultural
          note right of vw_lov_occupation_agricultural
            **WHERE** ddl_key = <color blue>**"$isicCode"**</color>
          end note
          note right of vw_lov_occupation_non_agricultural
            **WHERE** ddl_key = <color blue>**"$isicCode"**</color>
          end note
        vw_lov_occupation_agricultural --> zoral : get occupation_agricultural response
        deactivate vw_lov_occupation_agricultural
        vw_lov_occupation_non_agricultural --> zoral : get occupation_non_agricultural response
        deactivate vw_lov_occupation_non_agricultural
        zoral -> backend_parameter : Inquiry data from DB 
        activate backend_parameter
        note right of backend_parameter
            **WHERE** key_group = <color blue>**"CRR_CSR"**</color>
            **AND** key_name in [<color blue>**"CRR_CSR_HIDE_SECTION"**</color>]
        end note
        backend_parameter --> zoral : get master_backend_parameter response
        deactivate backend_parameter
        group filter mapping
        note right of zoral
           defaultNonAgri = !(occupation_agricultural.length > 0) and !(occupation_non_agricultural.length > 0)
          
           1. filter customerStatus and total_debt
           2. using response by step one filter by purpose . ex
              accountType
              accountGroup
              AgriCultural
              NonAgriCultural
              AllCondition
              DefaultNonAgriCultural
           3. return response
           common filter
           AccountGroup.length > 0
            |
            v   
           AccountType.length > 0 
            |
            v
           AgriCultural.length > 0
            |
            v   
           NonAgriCultural.length > 0 
            |
            v   
           AllCondition.length > 0 
            |
            v
           DefaultNonAgricultural.length > 0

        special case
          customerCode in ('603','600')
          if ['CREATE_LOAN','CHANGE_LOAN','OVERDRAFT'] and check backend parameter
           AccountGroup -> AccountType -> AgriCultural -> NonAgriCultural -> DefaultNonAgricultural
          else if ['CREATE_DBM','CHANGE_DBM','AUTO_DBM'] and accountType in ['8200','8500']
           AgriCultural -> NonAgriCultural -> AllCondition -> DefaultNonAgricultural
          else AllCondition
        end note
        
        end group
        zoral -> zoral : keep response to globalVariables mapping
            end alt      
        else mapping length == 1
        zoral -> zoral : keep response to globalVariables mapping
        else if mapping length == 0
        note right of zoral
          hard stop and return HTTP status 400
        end note
        end alt
  end group
  end group

