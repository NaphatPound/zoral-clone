  == Query From data ==

  group Query Form data
    zoral -> mas_corp_assessment_form : Inquiry data from DB

    activate mas_corp_assessment_form
      note right of mas_corp_assessment_form
        **WHERE** form_group = <color blue>**"$form_group"**</color>
      end note

    mas_corp_assessment_form --> zoral : Answer response

    deactivate mas_corp_assessment_form
 
    alt if any database error
      note right of zoral
        hard stop and return HTTP status 200, status.code = 9100
      end note
    end alt
  end group



  == Filter From ==

  group Check result.from.length
      zoral -> zoral : Check from length
      loop filter by property in form
       alt if businessType
       note right of zoral
         keep form_code
        end note
       else customerCode
       note right of zoral
         keep form_code
        end note
       else groupType and accountType
       note right of zoral
         keep form_code
        end note
       else groupType and !(property.accountType) and $accountType != 8100
       note right of zoral
         keep form_code
        end note
       else isMultiForm 
        note right of zoral
         globalVariable isMultiForm = true
        end note
       end alt
      zoral -> zoral : keep globalvariable selectForm form filter
      end 
  end group

